# ==============================================
#  .gitignore – Redrob Hackathon Submission
# ==============================================

# ── Files that exceed GitHub's 100 MB hard limit ─────────────────────────────
# Raw JSONL (~465 MB) – use data/candidates.zip (~54 MB) instead
data/candidates.jsonl

# Root-level zip that bundles the raw data (~108 MB)
data.zip

# ── Python cache & compiled bytecode ─────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# ── Build / packaging artefacts ───────────────────────────────────────────────
*.egg
*.egg-info/
dist/
build/
.eggs/
*.whl

# ── Virtual environments ──────────────────────────────────────────────────────
venv/
.venv/
env/
.env/
ENV/

# ── Environment variable files ────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ── IDE & editor files ────────────────────────────────────────────────────────
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# ── OS-generated files ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Jupyter notebooks ─────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Logs & temp files ─────────────────────────────────────────────────────────
*.log
*.tmp
*.temp

# ── pytest / coverage ─────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
